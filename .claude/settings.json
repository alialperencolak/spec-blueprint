{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(find . *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cp *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(chmod *)",
      "Bash(chown *)"
    ]
  },
  "autoCompactThreshold": 0.8,
  "includeCoAuthoredBy": true
}
